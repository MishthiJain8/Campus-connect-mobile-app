{
  "name": "campus-connect-monorepo",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "install:mobile": "cd apps/mobile && npm install",
    "install:api": "cd apps/api && npm install",
    "dev:mobile": "cd apps/mobile && npm start",
    "dev:api": "cd apps/api && npm run dev",
    "build:mobile": "cd apps/mobile && npm run build",
    "build:api": "cd apps/api && npm run build",
    "lint": "npm run lint --workspace=apps/api && npm run lint --workspace=apps/mobile",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.1.1",
    "typescript": "^5.3.3"
  }
}
